{
  "require": {
    "php": ">=7.4.0",
    "tracy/tracy": "2.7.3",
    "nette/tester": "2.0.2",
    "setasign/fpdf": "^1.8",
    "setasign/fpdi": "1.5.4",
    "nette/reflection": "2.4.2",
    "nette/nette": "3.0.0"
  },
  "autoload": {
    "classmap": []
  },
  "scripts": {
    "initTestDatabase": [
      "./tests/init-database.sh"
    ],
    "clearTestDatabase": [
      "./tests/clear-database.sh"
    ],
    "clearTestCache": [
      "rm -rf temp/tester/"
    ],
    "clearCache": [
      "rm -rf temp/cache/"
    ],
    "test": [
      "@clearTestCache",
      "@clearTestDatabase",
      "vendor/bin/tester tests -p php -s -c tests/php.ini"
    ],
    "testCoverage": [
      "@clearTestCache",
      "@clearTestDatabase",
      "vendor/bin/tester tests -p php --coverage coverage.html --coverage-src app -s -c tests/php.ini"
    ]
  }
}
